# Mot de passe pour accéder au dashboard (changer impérativement)
MULTIWEB_PASSWORD=change-me-please

# Domaine de base. Chaque site sera servi sur <nom>.<MULTIWEB_BASE_DOMAIN>
# Le dashboard sera sur dash.<MULTIWEB_BASE_DOMAIN>
MULTIWEB_BASE_DOMAIN=apps.exemple.com

# Optionnel - valeurs par défaut sensées
# MULTIWEB_SITES_DIR=/var/www/sites
# MULTIWEB_CADDY_SITES_DIR=/etc/caddy/sites.d
# MULTIWEB_CADDY_CONFIG=/etc/caddy/Caddyfile
# MULTIWEB_PORT=3000
# MULTIWEB_MAX_UPLOAD_MB=100
